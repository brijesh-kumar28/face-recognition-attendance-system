# ============ FACE ATTENDANCE SYSTEM - PRODUCTION CONFIGURATION ============

# ==================== SECURITY (CRITICAL) ====================

# JWT Secret Key - MUST be set for production
# Generate a strong secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit the actual secret to version control
# Default (development only): Uses dev key if not set
JWT_SECRET=your_super_secret_jwt_key_generate_with_secrets_module_min_32_chars

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=false

# ==================== FACE RECOGNITION ====================

# Face distance threshold for matching accuracy
# Lower values = stricter matching (fewer false positives)
# Default: 0.3 (strict, recommended for production)
# Range: 0.1-0.6
FACE_DISTANCE_THRESHOLD=0.3

# ==================== EVENT TRACKING (Optional) ====================

# Sentry error tracking (optional, for production monitoring)
# SENTRY_DSN=https://your-sentry-url

# ==================== DATABASE ====================

# Database file location (relative to backend directory)
# Default: attendance.db (SQLite)
DATABASE_PATH=attendance.db

# ==================== SERVER ====================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ==================== LOGGING ====================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== BACKUP (Optional) ====================

# Backup configuration
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ============ NOTES ============
# 1. JWT_SECRET: Generate unique secret for production
#    Command: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. FLASK_ENV: Always set to 'production' for live systems
#
# 3. FACE_DISTANCE_THRESHOLD: 
#    - 0.3 (strict) for security-critical apps
#    - 0.35-0.4 (moderate) for balanced accuracy
#
# 4. All secrets should be stored in environment, never in code
#
# 5. For production deployment, use:
#    - Strong, randomly generated secrets
#    - HTTPS only
#    - Secure database backups
#    - Rate limiting enabled (built-in)
#    - Security headers enabled (built-in)
